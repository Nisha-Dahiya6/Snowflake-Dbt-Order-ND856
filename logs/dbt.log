    b.loyalty_points,
    b.loyalty_tier,
    b.first_name,
    b.last_name,
    b.region,
    e.email,
    p.phone_type,
    p.phone_number
from base b
left join emails e using (customer_id)
left join phones p using (customer_id)
  )
